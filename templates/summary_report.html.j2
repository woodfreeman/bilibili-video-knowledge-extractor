<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ video.title }} - 视频内容总结报告</title>
  <style>
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.65;
      color: #1f2933;
      background: #f6f8fb;
    }
    main {
      max-width: 980px;
      margin: 0 auto;
      padding: 40px 20px 72px;
      background: #fff;
      min-height: 100vh;
    }
    h1, h2, h3 { line-height: 1.25; }
    h1 { margin-top: 0; }
    img {
      max-width: 100%;
      border: 1px solid #d9e2ec;
      border-radius: 6px;
      margin: 12px 0 24px;
    }
    table {
      border-collapse: collapse;
      width: 100%;
      overflow-wrap: anywhere;
    }
    th, td {
      border: 1px solid #d9e2ec;
      padding: 8px 10px;
      vertical-align: top;
    }
    th { background: #eef3f8; }
    code {
      background: #eef3f8;
      border-radius: 4px;
      padding: 2px 4px;
    }
  </style>
</head>
<body>
  <main>
    {{ markdown_html | safe }}
  </main>
</body>
</html>
